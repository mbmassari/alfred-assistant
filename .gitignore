# Secrets - NEVER commit real secrets
secrets/*
!secrets/.gitkeep
!secrets/README.md

# Environment
.env
.env.local
.env.production

# Claude
.claude/

# Obsidian
.obsidian/

# Python
__pycache__/
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/

